<?xml version="1.0" encoding="UTF-8"?>
<con:soapui-project id="banking-api-project" name="Banking App API Tests"
                     resourceRoot="" soapui-version="5.7.0"
                     xmlns:con="http://eviware.com/soapui/config">
  <con:settings/>
  <con:interface xsi:type="con:RestService" id="banking-api" name="Banking API"
                 type="rest" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
    <con:settings/>
    <con:definitionCache type="TEXT" rootPart=""/>
    <con:endpoints>
      <con:endpoint>http://banking-app</con:endpoint>
    </con:endpoints>

    <!-- Health Check Resource -->
    <con:resource name="Health" path="/actuator/health" id="health-resource">
      <con:settings/>
      <con:parameters/>
      <con:method name="Health Check" id="health-check" method="GET">
        <con:settings/>
        <con:parameters/>
        <con:representation type="RESPONSE">
          <con:mediaType>application/json</con:mediaType>
          <con:status>200</con:status>
        </con:representation>
        <con:request name="Request 1" id="health-check-req" mediaType="application/json">
          <con:settings/>
          <con:endpoint>http://banking-app</con:endpoint>
          <con:request/>
          <con:credentials>
            <con:selectedAuthProfile>No Authorization</con:selectedAuthProfile>
            <con:authType>No Authorization</con:authType>
          </con:credentials>
          <con:jmsConfig JMSDeliveryMode="PERSISTENT"/>
          <con:parameters/>
        </con:request>
      </con:method>
    </con:resource>

    <!-- Accounts Resource -->
    <con:resource name="Accounts" path="/api/accounts" id="accounts-resource">
      <con:settings/>
      <con:parameters/>
      <con:method name="Get All Accounts" id="get-accounts" method="GET">
        <con:settings/>
        <con:parameters/>
        <con:representation type="RESPONSE">
          <con:mediaType>application/json</con:mediaType>
          <con:status>200</con:status>
        </con:representation>
        <con:request name="Request 1" id="get-accounts-req" mediaType="application/json">
          <con:settings/>
          <con:endpoint>http://banking-app</con:endpoint>
          <con:request/>
          <con:credentials>
            <con:selectedAuthProfile>No Authorization</con:selectedAuthProfile>
            <con:authType>No Authorization</con:authType>
          </con:credentials>
          <con:jmsConfig JMSDeliveryMode="PERSISTENT"/>
          <con:parameters/>
        </con:request>
      </con:method>
    </con:resource>

    <!-- Users Resource -->
    <con:resource name="Users" path="/api/users" id="users-resource">
      <con:settings/>
      <con:parameters/>
      <con:method name="Get All Users" id="get-users" method="GET">
        <con:settings/>
        <con:parameters/>
        <con:representation type="RESPONSE">
          <con:mediaType>application/json</con:mediaType>
          <con:status>200</con:status>
        </con:representation>
        <con:request name="Request 1" id="get-users-req" mediaType="application/json">
          <con:settings/>
          <con:endpoint>http://banking-app</con:endpoint>
          <con:request/>
          <con:credentials>
            <con:selectedAuthProfile>No Authorization</con:selectedAuthProfile>
            <con:authType>No Authorization</con:authType>
          </con:credentials>
          <con:jmsConfig JMSDeliveryMode="PERSISTENT"/>
          <con:parameters/>
        </con:request>
      </con:method>
    </con:resource>
  </con:interface>

  <!-- Test Suite -->
  <con:testSuite id="banking-test-suite" name="Banking API Test Suite">
    <con:settings/>
    <con:runType>SEQUENTIAL</con:runType>

    <!-- Health Check Test Case -->
    <con:testCase id="health-test" name="Health Check Test" failOnError="true" failTestCaseOnErrors="true" keepSession="false">
      <con:settings/>
      <con:testStep type="restrequest" name="Health Check" id="health-step">
        <con:settings/>
        <con:config service="Banking API" methodName="Health Check" resourcePath="/actuator/health" xsi:type="con:RestRequestStep" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
          <con:restRequest name="Health Check" id="health-check-req" mediaType="application/json">
            <con:settings/>
            <con:endpoint>http://banking-app</con:endpoint>
            <con:request/>
            <con:credentials>
              <con:selectedAuthProfile>No Authorization</con:selectedAuthProfile>
              <con:authType>No Authorization</con:authType>
            </con:credentials>
            <con:jmsConfig JMSDeliveryMode="PERSISTENT"/>
            <con:parameters/>
            <con:assertion type="Valid HTTP Status Codes" id="status-assertion" name="Valid HTTP Status Codes">
              <con:configuration>
                <codes>200</codes>
              </con:configuration>
            </con:assertion>
            <con:assertion type="JsonPath Match" id="json-assertion" name="JsonPath Match">
              <con:configuration>
                <path>$.status</path>
                <content>UP</content>
                <allowWildcards>false</allowWildcards>
                <ignoreNamspaceDifferences>false</ignoreNamspaceDifferences>
                <ignoreComments>false</ignoreComments>
              </con:configuration>
            </con:assertion>
          </con:restRequest>
        </con:config>
      </con:testStep>
    </con:testCase>

    <!-- Accounts Test Case -->
    <con:testCase id="accounts-test" name="Accounts API Test" failOnError="true" failTestCaseOnErrors="true" keepSession="false">
      <con:settings/>
      <con:testStep type="restrequest" name="Get All Accounts" id="accounts-step">
        <con:settings/>
        <con:config service="Banking API" methodName="Get All Accounts" resourcePath="/api/accounts" xsi:type="con:RestRequestStep" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
          <con:restRequest name="Get All Accounts" id="get-accounts-req" mediaType="application/json">
            <con:settings/>
            <con:endpoint>http://banking-app</con:endpoint>
            <con:request/>
            <con:credentials>
              <con:selectedAuthProfile>No Authorization</con:selectedAuthProfile>
              <con:authType>No Authorization</con:authType>
            </con:credentials>
            <con:jmsConfig JMSDeliveryMode="PERSISTENT"/>
            <con:parameters/>
            <con:assertion type="Valid HTTP Status Codes" id="status-assertion" name="Valid HTTP Status Codes">
              <con:configuration>
                <codes>200</codes>
              </con:configuration>
            </con:assertion>
          </con:restRequest>
        </con:config>
      </con:testStep>
    </con:testCase>

    <!-- Users Test Case -->
    <con:testCase id="users-test" name="Users API Test" failOnError="true" failTestCaseOnErrors="true" keepSession="false">
      <con:settings/>
      <con:testStep type="restrequest" name="Get All Users" id="users-step">
        <con:settings/>
        <con:config service="Banking API" methodName="Get All Users" resourcePath="/api/users" xsi:type="con:RestRequestStep" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
          <con:restRequest name="Get All Users" id="get-users-req" mediaType="application/json">
            <con:settings/>
            <con:endpoint>http://banking-app</con:endpoint>
            <con:request/>
            <con:credentials>
              <con:selectedAuthProfile>No Authorization</con:selectedAuthProfile>
              <con:authType>No Authorization</con:authType>
            </con:credentials>
            <con:jmsConfig JMSDeliveryMode="PERSISTENT"/>
            <con:parameters/>
            <con:assertion type="Valid HTTP Status Codes" id="status-assertion" name="Valid HTTP Status Codes">
              <con:configuration>
                <codes>200</codes>
              </con:configuration>
            </con:assertion>
          </con:restRequest>
        </con:config>
      </con:testStep>
    </con:testCase>
  </con:testSuite>

  <con:properties/>
  <con:wssContainer/>
  <con:oAuth2ProfileContainer/>
  <con:oAuth1ProfileContainer/>
  <con:sensitiveInformation/>
</con:soapui-project>
